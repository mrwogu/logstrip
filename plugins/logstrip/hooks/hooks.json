{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"require(require('node:path').join(process.env.DROID_PLUGIN_ROOT||process.env.CLAUDE_PLUGIN_ROOT,'hooks','logstrip-hook.js'))\"",
            "timeout": 10,
            "statusMessage": "LogStrip: compressing log file..."
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"require(require('node:path').join(process.env.DROID_PLUGIN_ROOT||process.env.CLAUDE_PLUGIN_ROOT,'hooks','logstrip-hook.js'))\"",
            "timeout": 5,
            "statusMessage": "LogStrip: checking for pasted logs..."
          }
        ]
      }
    ]
  }
}
